DB_URL=
QUESTION=
METADATA_CACHE_ENABLED=

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat

SCHEMA_API_KEY=
SCHEMA_BASE_URL=https://api.deepseek.com
